@model List<DeStaProduction.Infrastucture.Entities.Performance>

@{
    ViewData["Title"] = "Начало";
}

<section class="hero">
    <video autoplay muted loop class="hero-video">
        <source src="/videos/theater.mp4" type="video/mp4">
    </video>

    <div class="hero-overlay">
        <h1>DeSta Production</h1>
        <p>Магията на театъра започва тук</p>
        <a href="#performances" class="btn-main">Виж представления</a>
    </div>
</section>
<section id="performances" class="performances-section">
    <div class="section-header">
        <h2 class="section-title">Предстоящи представления</h2>
    </div>

    <div class="cards-container">
        @foreach (var item in Model)
        {
            <div class="performance-card ticket">
                <div class="ticket-left">
                    <h3>@item.Title</h3>
                    <p>@item.Date.ToString("dd MMM yyyy HH:mm")</p>
                    <p>@item.Location</p>
                </div>

                <div class="ticket-right">
                    <span>THEATER</span>
                </div>
            </div>
        }
    </div>
</section>
<script src="https://cdn.jsdelivr.net/npm/particles.js"></script>

<div id="particles-js"></div>

<script>
    particlesJS("particles-js", {
      particles: {
        number: { value: 50 },
        size: { value: 3 },
        color: { value: "#ffd700" },
        line_linked: { enable: true, color: "#ffd700" }
      }
    });
</script>