.hero {
    height: 80vh;
    background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)),
                url('https://images.unsplash.com/photo-1503095396549-807759245b35');
    background-size: cover;
    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
    text-align: center;
}

.hero h1 {
    font-size: 70px;
    animation: fadeUp 1s ease;
}

.btn-main {
    background: red;
    padding: 12px 25px;
    border-radius: 10px;
    color: white;
    text-decoration: none;
}

.section.dark {
    background: #111;
    color: white;
    padding: 60px;
}

.cards {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
}

.card {
    background: #222;
    padding: 20px;
    border-radius: 10px;
    width: 220px;
    transition: 0.3s;
}

.card:hover {
    transform: scale(1.05);
}

.fade-in {
    animation: fadeIn 1s ease;
}