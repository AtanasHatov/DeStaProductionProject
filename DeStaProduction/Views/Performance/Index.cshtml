@using DeStaProduction.ViewModels
@model IEnumerable<PerformanceViewModel>

<h2>Представления</h2>
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-2">Добави представление</a>
}
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Заглавие</th>
            <th>Репертоарно заглавие</th>
            <th>Локация</th>
            <th>Дата</th>
            @if (User.IsInRole("Admin"))
            {
                <th>Действия</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Title</td>
                <td>@p.Event</td>
                <td>@p.Location</td>
                <td>@p.Date.ToString("dd.MM.yyyy HH:mm")</td>
                @if (User.IsInRole("Admin"))
                {
                    <td>
                        <form asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline">
                            <button class="btn btn-danger btn-sm">Изтрий</button>
                        </form>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
