@model DeStaProduction.Infrastucture.Entities.Schedule
@{
    var performances = ViewBag.Performances;
}

<div class="theater-form-container">

    <h2 class="form-title">🎬 Задача към актьор</h2>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="custom-error">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <form method="post" class="theater-form">

        <div class="form-group">
            <label>📅 Дата</label>
            <input asp-for="Date" type="datetime-local" class="form-control" />
        </div>

        <div class="form-group">
            <label>👤 Актьор</label>
            <select asp-for="UserId" asp-items="ViewBag.Actors" class="form-control"></select>
        </div>

        <div class="form-group">
            <label>🎭 Представление</label>
            <select asp-for="PerformanceId" class="form-control">
                @foreach (var performance in performances)
                {
                    <option value="@performance.Value">@performance.Text</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label>📝 Описание</label>
            <textarea asp-for="Notes" class="form-control"></textarea>
        </div>

        <div class="form-group">
            <label>🎬 Тип</label>
            <select asp-for="Type" class="form-control">
                <option value="Performance">Представление</option>
                <option value="Rehearsal">Репетиция</option>
                <option value="Setup">Строене на сцена</option>
                <option value="Personal">Друго</option>
            </select>
        </div>

        <button class="btn theater-btn">🎭 Запази</button>

    </form>
</div>