@model DeStaProduction.Infrastucture.Entities.Schedule
@{
    var performances = ViewBag.Performances;
}

<h2>Задача към актьор</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<form method="post">
    <input asp-for="Date" type="datetime-local" class="form-control mb-2" />

    <select asp-for="UserId" asp-items="ViewBag.Actors" class="form-control mb-2"></select>

    <select asp-for="PerformanceId" class="form-control mb-2">
        @foreach(var performance in performances)
        {
            <option value="@performance.Value">@performance.Text</option>
        }
    </select>

    <textarea asp-for="Notes" class="form-control mb-2"></textarea>

    <div class="form-group">
        <label>Тип</label>
        <select asp-for="Type" class="form-control">
            <option value="Performance">Представление</option>
            <option value="Rehearsal">Репетиция</option>
            <option value="Setup">Строене на сцена</option>
            <option value="Personal">Друго</option>
        </select>
    </div>

    <button class="btn btn-warning">Запази</button>
</form>