@using DeStaProduction.Infrastucture.Entities
@model IEnumerable<Schedule>

<h2>Calendar</h2>

@if (User.IsInRole("Admin"))
{
    <div class="mb-3">
        <a asp-action="AssignTask" class="btn btn-warning">Task</a>
        <a asp-action="AddPerformance" class="btn btn-primary">Performance</a>
        <a asp-action="MyTask" class="btn btn-dark">My Task</a>
    </div>
}
<div class="d-flex justify-content-between mb-3">
    <a asp-action="Index" asp-route-month="@(ViewBag.Month - 1)" asp-route-year="@ViewBag.Year">←</a>
    <h4>@ViewBag.Month / @ViewBag.Year</h4>
    <a asp-action="Index" asp-route-month="@(ViewBag.Month + 1)" asp-route-year="@ViewBag.Year">→</a>
</div>

<div class="row">
    @for (int day = 1; day <= DateTime.DaysInMonth(ViewBag.Year, ViewBag.Month); day++)
    {
        @foreach (var s in Model.Where(x => x.Date.Day == day))
        {
            var color = s.Type switch
            {
                "Performance" => "bg-primary",
                "Rehearsal" => "bg-warning",
                "Setup" => "bg-secondary",
                "Personal" => "bg-dark",
                _ => "bg-info"
            };

            <div class="mt-1 p-1 text-white rounded @color">
                <small>@s.Type</small><br />
                <small>@s.Performance?.Title</small><br />
                <small>@s.User.UserName</small>

                @if (User.IsInRole("Artist") && s.UserId == Guid.Parse(User.FindFirst("sub")!.Value))
                {
                    <form asp-action="Availability" method="post">
                        <input type="hidden" name="id" value="@s.Id" />
                        <button name="isAvailable" value="true" class="btn btn-success btn-sm">✔</button>
                        <button name="isAvailable" value="false" class="btn btn-danger btn-sm">✖</button>
                    </form>
                }
            </div>
        }
    }
</div>
