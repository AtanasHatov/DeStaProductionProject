@model RegisterViewModel
<div class="auth-container">
@{
    ViewData["Title"] = "Регистрация";
}

<h1 class="text-center">@ViewData["Title"]</h1>

    <div class="form-wrapper">
        <form id="registerForm" method="post">
            <hr />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FirstName">Собствено име</label>
                    <input class="form-control" asp-for="FirstName" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="LastName">Фамилия</label>
                    <input class="form-control" asp-for="LastName" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
            <div class="text-center mb-3">
                <label asp-for="Email">Имейл</label>
                <input class="form-control"
                       asp-for="Email"
                       autocomplete="email"
                       aria-required="true" />
                <span asp-validation-for="Email" class="text-danger"></span> 
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Password">Парола</label>
                    <input class="form-control" asp-for="Password" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Потвърди паролата</label>
                    <input class="form-control" asp-for="ConfirmPassword" type="password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>
            <div class="text-center mb-4">
                <label asp-for="Role">Регистрирай се като:</label>
                <select class="form-control" asp-for="Role">
                    <option value="">Избери роля</option>
                    <option value="Artist">Актьор</option>
                    <option value="User">Потребител</option>
                </select>
            </div>
            <div class="text-center">
                <button id="registerSubmit" type="submit" class="btn btn-primary">
                    Регистрация
                </button>
            </div>
        </form>
    </div>
</div>
