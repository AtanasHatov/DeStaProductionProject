@model IEnumerable<DeStaProduction.ViewModels.EventViewModel>

<div class="repertoire-container">

    <h1 class="repertoire-title">🎭 Репертоар</h1>
    @if (User.IsInRole("Admin"))
    {
        <div class="text-center mb-4">
            <a asp-action="Create" class="btn theater-btn">
                ➕ Добави представление
            </a>
        </div>
    }

    <div class="repertoire-grid">

        @foreach (var item in Model)
        {
            <div class="repertoire-card">


                <div class="card-image">
                    <img src="@(string.IsNullOrWhiteSpace(item.ImagePath)
        ? "/images/default-poster.jpg"
        : item.ImagePath)"
                         alt="@item.Title" />
                </div>

              
                <div class="card-content">

                    <h3>@item.Title</h3>

                    <p class="type">@item.TypeName</p>

                    <p class="desc">
                        @(item.Description?.Length > 100
                            ? item.Description.Substring(0, 100) + "..."
                            : item.Description)
                    </p>

                    <p class="duration">⏱ @item.Duration мин</p>

                    <a asp-action="Details" asp-route-id="@item.Id" class="btn details-btn">
                        🎟️ Детайли
                    </a>

                </div>
            </div>
        }

    </div>
</div>