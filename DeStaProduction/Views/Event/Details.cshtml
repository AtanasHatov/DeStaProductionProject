@model DeStaProduction.ViewModels.EventViewModel

<div class="event-details-page">

    <div class="details-card">

        <div class="details-image-wrapper">
            <img src="@(string.IsNullOrWhiteSpace(Model.ImagePath)
        ? "/images/default-poster.jpg"
        : Model.ImagePath)"
                 alt="@Model.Title"
                 class="details-image" />
        </div>

        <div class="details-content">

            <h1>@Model.Title</h1>

            <p class="details-type">@Model.TypeName</p>

            <p class="details-desc">@Model.Description</p>

            <div class="details-info">
                ⏱ @Model.Duration минути
            </div>

            <h3>🎭 Предстоящи представления</h3>

            @if (Model.Performances != null && Model.Performances.Any())
            {
                foreach (var p in Model.Performances)
                {
                    <div class="performance-item">
                        📅 @p.Date.ToString("dd MMM yyyy HH:mm")
                        📍 @p.Location
                    </div>
                }
            }
            else
            {
                <p>Няма предстоящи представления</p>
            }

        </div>

    </div>

</div>