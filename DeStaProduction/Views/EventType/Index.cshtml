@using DeStaProduction.ViewModels
@model IEnumerable<EventTypeViewModel>

<h2>Категории събития</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Създай нова категория събитие</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Име</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>
