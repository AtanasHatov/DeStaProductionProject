@using DeStaProduction.ViewModels
@model IEnumerable<LocationViewModel>

<h2>Локации</h2>

<a asp-action="Create" class="btn btn-primary mb-2">Създай локация</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Име</th>
            <th>Град</th>
            <th>Капацитет на залата</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var location in Model)
        {
            <tr>
                <td>@location.Name</td>
                <td>@location.City</td>
                <td>@location.Capacity</td>
                <td>
                    <a asp-action="Details" asp-route-id="@location.Id">Детайли</a> |
                    <a asp-action="Delete" asp-route-id="@location.Id">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>
