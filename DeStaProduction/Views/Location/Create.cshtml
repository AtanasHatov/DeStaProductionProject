@model DeStaProduction.ViewModels.LocationViewModel

<section class="create-page">

    <div class="create-container small-form">

        <h2>Добави локация</h2>

        <form method="post">

            <div class="form-group">
                <label>Име</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="form-group">
                <label>Град</label>
                <input asp-for="City" class="form-control" />
            </div>

            <div class="form-group">
                <label>Адрес</label>
                <input asp-for="Address" class="form-control" />
            </div>

            <div class="form-group">
                <label>Капацитет</label>
                <input asp-for="Capacity" class="form-control" />
            </div>

            <button class="btn-create">Създай</button>

        </form>

    </div>

</section>